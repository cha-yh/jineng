#!/usr/bin/env bash
set -e
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in
    /*) ;;
    *) SOURCE="$DIR/$SOURCE" ;;
  esac
done
DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ROOT="$(cd "$DIR/.." && pwd)"
# Install dependencies from the repository root when the package has not been linked yet.
if [ ! -d "$ROOT/node_modules/chalk" ]; then
  echo "[jineng] installing dependencies..." >&2
  if command -v pnpm >/dev/null 2>&1; then
    (cd "$ROOT" && pnpm install)
  else
    echo "[jineng] pnpm not found. Install from the repo root: cd $ROOT && pnpm install" >&2
    exit 1
  fi
fi
if [ ! -f "$ROOT/dist/src/cli/index.js" ]; then
  (cd "$ROOT" && npm run build)
fi
exec node "$ROOT/dist/src/cli/index.js" "$@"
